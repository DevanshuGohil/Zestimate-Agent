# Required
MISTRAL_API_KEY=
RAPIDAPI_KEY=

# LLM (optional overrides)
MISTRAL_MODEL=mistral-small-latest
MISTRAL_FALLBACK_MODEL=open-mistral-7b

# Primary provider
RAPIDAPI_HOST=zillow56.p.rapidapi.com

# Optional: Google Maps Geocoding API key (improves normalization accuracy)
GOOGLE_MAPS_API_KEY=

# Optional: rotating proxy for DirectProvider (format: http://user:pass@host:port)
# Treated as a secret — credentials in the URL never appear in logs or repr(settings)
PROXY_URL=

# Request timeout — max seconds a /lookup is allowed to run before returning 504
REQUEST_TIMEOUT_SECONDS=30

# CORS — comma-separated list of allowed origins (leave empty for same-origin only)
# CORS_ORIGINS=https://your-frontend.com,https://staging.your-frontend.com

# Rate limiting (per IP per minute)
RATE_LIMIT_LOOKUP=10/minute
RATE_LIMIT_CACHE=5/minute

# Cache
CACHE_TTL_HOURS=24
CACHE_FAILURE_TTL_HOURS=6

# Observability
LOG_LEVEL=INFO

# LangSmith tracing (optional — set both to enable)
# The agent automatically propagates these to LANGSMITH_TRACING /
# LANGCHAIN_TRACING_V2 when LANGSMITH_TRACING=true is set here.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
# LANGSMITH_PROJECT defaults to "zestimate-agent" when tracing is enabled
